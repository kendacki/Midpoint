# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/artifacts
/cache

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - never commit real secrets
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.development
.env.staging
.env*.local
!.env.example

# secrets and credentials
secrets.json
credentials.json
private-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
temp_auto_push.bat
temp_interactive_push.bat
branch_structure.json
